  "beginning": "\u3010\u6d4b\u8bd5\u5f00\u573a\u767d\u3011\u6668\u661f\u5728\u5854\u5e95\u5e9f\u589f\u7ad9\u5b9a\uff0c\u6307\u5c16\u6263\u4f4f\u6cd5\u6756\u3002\n\n<g3>\nname={{user}};gender=\u7537\u6027;loc=\u661f\u9668\u5927\u9646-\u661f\u9668\u738b\u56fd-\u5e9f\u5f03\u6cd5\u5e08\u5854-\u5e95\u5c42\u5927\u5385;time=\u661f\u53861472\u5e749\u670815\u65e5 \u9ec4\u660f;armor=15;hp=45/45;mp=65/100;sp=80/100;race=3\u7ea7\u7cbe\u7075|100/300;cls=4\u7ea7\u5965\u672f\u5e08|200/400;stats=\u4f53\u8d28:10,\u529b\u91cf:8,\u654f\u6377:14,\u667a\u529b:18,\u611f\u77e5:15,\u9b45\u529b:16;equip=\u5934\u9970:\u6708\u591c\u8f89\u51a0|\u611f\u77e5+3\u667a\u529b+6,\u4e3b\u6b66\u5668:\u7d2b\u6728\u6cd5\u6756|\u6bcf\u51fb1d4\u949d+1d4\u5965\u672f,\u5168\u8eab:\u6708\u767d\u5965\u6cd5\u888d;skill=\u6cd5\u672f:\u5965\u672f\u98de\u5f39|\u6d88\u80175\u9b54\u6cd5\u53d13\u98de\u5f39,\u6cd5\u672f:\u971c\u51bb\u65b0\u661f|\u6d88\u801715\u9b54\u6cd5\u51bb\u7ed3\u5e762d6\u5bd2\u971c,\u5929\u8d4b:\u9ed1\u6697\u89c6\u89c9;bag=\u6d88\u8017\u54c1|\u5f3a\u6548\u6062\u590d\u836f\u52422\u74f6/\u521d\u7ea7\u89e3\u6bd2\u5242/\u7167\u660e\u5377\u8f743\u5377;goal=\u6d88\u706d\u77f3\u50cf\u9b3c\u5e76\u5bfb\u627e\u4e0a\u5c42\u5b9e\u9a8c\u5ba4\u7684\u9690\u85cf\u9636\u68af;event=1/3|\u6682\u65e0;turn=5;opt=\u65bd\u653e\u971c\u51bb\u65b0\u661f|\u6d88\u8017\u9b54\u6cd5\u5236\u9020\u5927\u8303\u56f4\u51b0\u51bb\uff0c\u5ef6\u7f13\u77f3\u50cf\u9b3cB\u7684\u4fa7\u7ffc\u5305\u6284\n</g3>",
